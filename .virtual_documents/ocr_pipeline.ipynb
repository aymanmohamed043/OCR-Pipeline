def binarize_otsu(gray_image: np.ndarray) -> np.ndarray:
    """
    Convert an image to binary using Otsu thresholding.
    """

    _, binary_image = cv.threshold(
        gray_image,
        0,
        255,
        cv.THRESH_BINARY + cv.THRESH_OTSU
    )

    return binary_image


