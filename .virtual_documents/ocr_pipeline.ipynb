from pytesseract import Output

def get_tesseract_data(image: np.ndarray, config: str = "--oem 3 --psm 6") -> dict:
    """
    Run Tesseract and return structured OCR data.
    """
    data = pytesseract.image_to_data(image, config=config, output_type=Output.DICT)
    return data


data = get_tesseract_data(invoice1_gray)


data


def draw_tesseract_boxes(image: np.ndarray, data: dict, min_conf: int = 0) -> np.ndarray:
    """
    Draw word-level bounding boxes from Tesseract OCR data.
    """
    output = image.copy()

    n = len(data["text"])

    for i in range(n):
        text = data["text"][i].strip()
        conf = int(float(data["conf"][i]))

        if conf < min_conf or text == "":
            continue

        x = data["left"][i]
        y = data["top"][i]
        w = data["width"][i]
        h = data["height"][i]

        cv.rectangle(output, (x, y), (x + w, y + h), (0, 255, 0), 2)

    return output, data["text"] 


output,text = draw_tesseract_boxes(invoice1_gray, data)


cv.imshow("invoice binary", output)
